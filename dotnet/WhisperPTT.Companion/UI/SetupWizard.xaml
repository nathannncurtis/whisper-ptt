<ui:FluentWindow x:Class="WhisperPTT.Companion.UI.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="WhisperPTT Setup"
        Width="640" Height="600" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        FontFamily="{DynamicResource ContentControlThemeFontFamily}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="WhisperPTT Setup" ShowMinimize="False" ShowMaximize="False" />

        <Grid Grid.Row="1" Margin="18,10,18,0">
            <!-- Step 1: language -->
            <StackPanel x:Name="StepLanguage">
                <ui:TextBlock FontTypography="Subtitle" Text="Choose your dictation language" />
                <ui:TextBlock Appearance="Secondary" Margin="0,4,0,0"
                              Text="English unlocks specialized models with better accuracy at the same speed." />
                <ui:Card Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="LANGUAGE" Margin="0,0,0,8" />
                        <ComboBox x:Name="LanguageBox" SelectedIndex="0" />
                    </StackPanel>
                </ui:Card>
            </StackPanel>

            <!-- Step 2: hardware scan -->
            <StackPanel x:Name="StepScan" Visibility="Collapsed">
                <ui:TextBlock FontTypography="Subtitle" Text="Your hardware" />
                <ui:TextBlock Appearance="Secondary" Margin="0,4,0,0"
                              Text="The model recommendation is based on this scan." />
                <ui:Card Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="PROCESSOR" Margin="0,0,0,2" />
                        <ui:TextBlock x:Name="CpuText" Text="scanning…" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="MEMORY" Margin="0,10,0,2" />
                        <ui:TextBlock x:Name="RamText" Text="…" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="NEURAL PROCESSOR" Margin="0,10,0,2" />
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="NpuDot" Width="9" Height="9" Margin="0,1,7,0" VerticalAlignment="Center" />
                            <ui:TextBlock x:Name="NpuText" Text="…" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
                <ui:Card Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="LLM CLEANUP (EXPERIMENTAL)" Margin="0,0,0,8" />
                        <CheckBox x:Name="LlmCheck" Content="Also install a small LLM that tidies punctuation and filler words" />
                        <ui:TextBlock x:Name="LlmNote" Appearance="Secondary" Margin="0,6,0,0" TextWrapping="Wrap"
                                      Text="Honest note: current-gen Intel NPUs run LLMs slowly; dictation works great without it, and it changes the Whisper recommendation to keep things snappy." />
                    </StackPanel>
                </ui:Card>
            </StackPanel>

            <!-- Step 3: recommendation -->
            <StackPanel x:Name="StepModel" Visibility="Collapsed">
                <ui:TextBlock FontTypography="Subtitle" Text="Recommended model" />
                <ui:Card Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="RECOMMENDED" Margin="0,0,0,8" />
                        <ui:TextBlock x:Name="RecName" FontSize="22" FontWeight="SemiBold" Text="…" />
                        <ui:TextBlock x:Name="RecMeta" Appearance="Secondary" Margin="0,2,0,0" Text="…" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="OR PICK ANOTHER" Margin="0,0,0,8" />
                        <ComboBox x:Name="ModelBox" />
                    </StackPanel>
                </ui:Card>
                <ui:TextBlock x:Name="LlmPlanText" Appearance="Secondary" Margin="2,10,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 4: install -->
            <StackPanel x:Name="StepInstall" Visibility="Collapsed">
                <ui:TextBlock FontTypography="Subtitle" Text="Installing" />
                <ui:Card Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="DOWNLOAD" Margin="0,0,0,8" />
                        <ui:TextBlock x:Name="InstallStatus" Text="starting…" TextWrapping="Wrap" />
                        <ProgressBar x:Name="InstallBar" Margin="0,10,0,0" Height="6" Minimum="0" Maximum="100" />
                    </StackPanel>
                </ui:Card>
                <ui:InfoBar x:Name="DoneBar" Margin="0,14,0,0" IsOpen="False" IsClosable="False"
                            Severity="Success" Title="Ready"
                            Message="Model installed and config updated. Start dictating!" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="18,14,18,18">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="BackBtn" Content="Back" Click="OnBack" Visibility="Collapsed" />
                <ui:Button x:Name="NextBtn" Content="Next" Appearance="Primary" Margin="8,0,0,0" Click="OnNext" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
